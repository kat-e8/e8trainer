extends layout
include _includes/sharedHTMLfunctions

block content
    .row.banner
        .col-12
            h1= pageHeader.title
                small &nbsp;#{pageHeader.strapline}
    .row.margin-top
        .col-12.col-md-8
            a.btn.btn-primary.float-right.button(href=`/add-student`) Add Student
    .row
        .col-12.col-md-8
            .error= message
            each student in students.reverse()
                .card
                    .card-block
                        h4
                            a(href=`/students/${student._id}`)= student.name
                            small &nbsp;
                                +outputRating(student.rating)
                            small &nbsp;
                            a.btn.btn-primary.float-right.button(href=`/students/${student._id}/delete`) Remove
                        p.address= student.role
                        p.address= student.qualification
                        
        .col-12.col-md-4
            p.lead= sidebar.context
block scripts
        
extends layout 

block content
    h1= title 
    p Welcome to e8Trainer, 
    .row
    .col-12.col-lg-9
      .row
        .col-12.col-md-6
          p  #{course.name} - #{course.description}
          small &nbsp;
              +outputRating(course.rating)
        .col-12.col-md-6.location-map
          .card.card-primary
            .card-block
              h2.card-title Ignition Training by Element8
              img.img-fluid.rounded(src=`/images/trainer.jpg`)